# Database
DATABASE_URL="postgresql://user:password@localhost:5432/eduhub"

# Admin credentials (used for seeding)
ADMIN_EMAIL="admin@eduhub.local"
ADMIN_PASSWORD="ChangeMe123!"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=5000
NODE_ENV="development"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Cloudflare (for R2 and Stream)
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_API_TOKEN="your-api-token"
CLOUDFLARE_R2_BUCKET_NAME="eduhub"
CLOUDFLARE_STREAM_CUSTOMER_CODE="your-customer-code"
